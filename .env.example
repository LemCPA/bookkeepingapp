# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# QuickBooks Online OAuth
QBO_CLIENT_ID=your-qbo-client-id
QBO_CLIENT_SECRET=your-qbo-client-secret
QBO_REDIRECT_URI=http://localhost:3000/api/auth/qbo-callback

# Email (for verification emails in production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Database
DB_PATH=.data/bookkeeping.json
